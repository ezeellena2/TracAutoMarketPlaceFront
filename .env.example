# TracAuto Marketplace - Variables de Entorno
# Copiar a .env.local para desarrollo local

# ==========================================
# API BACKEND
# ==========================================
# URL base del backend TracAuto (sin trailing slash)
VITE_API_BASE_URL=http://localhost:5200/api

# Versión de la API
VITE_API_VERSION=v1

# ==========================================
# CONFIGURACIÓN OPCIONAL
# ==========================================
# Timeout para requests en milisegundos (default: 30000)
# VITE_API_TIMEOUT=30000
